# ExpertAims — cPanel/Apache deployment config
# (GitHub Pages ignores this file; it activates when the site is hosted
#  on the expertaims.com cPanel server.)

# Force HTTPS + canonical www — ONLY on the production domain, so preview
# deployments (e.g. clients.expertaims.in/eac) are left untouched.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^expertaims\.com$ [NC]
  RewriteRule ^(.*)$ https://www.expertaims.com/$1 [L,R=301]
  RewriteCond %{HTTP_HOST} ^www\.expertaims\.com$ [NC]
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://www.expertaims.com/$1 [L,R=301]
</IfModule>

# Custom error page
ErrorDocument 404 /404.html

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json text/plain
</IfModule>

# Cache policy: HTML fresh, assets long-lived
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
</IfModule>

# Never serve repo internals
RedirectMatch 404 /\.git
